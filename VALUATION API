const router = require("express").Router();

router.post("/", (req, res) => {
  const { year, condition, mileage } = req.body;

  let age = new Date().getFullYear() - year;
  let value = 2000000 * (1 - age * 0.08);
  value *= condition;

  if (mileage > 100000) value *= 0.8;
  else if (mileage > 60000) value *= 0.9;

  if (value < 200000) value = 200000;

  res.json({ value: Math.round(value) });
});

module.exports = router;
