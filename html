top:0;
z-index:999;
border-bottom:1px solid #222
}
nav{
max-width:1300px;
margin:auto;
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:15px
}
.logo{
font-size:30px;
font-weight:700;
color:#facc15
}
.menu{
display:flex;
gap:15px;
flex-wrap:wrap
}
.menu a{
text-decoration:none;
color:#ddd;
font-size:14px
}
.menu a:hover{color:#facc15}

.hero{
padding:90px 20px;
text-align:center;
background:linear-gradient(135deg,#0a0f1c,#16213e,#0a0f1c)
}
.hero h1{
font-size:58px;
line-height:1.1;
margin-bottom:20px
}
.hero span{color:#facc15}
.hero p{
max-width:760px;
margin:auto;
color:#cbd5e1;
font-size:20px
}
.pass{
margin-top:25px;
font-size:34px;
font-weight:700;
color:#22d3ee
}
.btn{
display:inline-block;
margin-top:25px;
padding:14px 28px;
border:none;
border-radius:10px;
background:#facc15;
color:#000;
font-weight:700;
cursor:pointer;
text-decoration:none
}
.btn:hover{opacity:.92}

.section{
max-width:1300px;
margin:auto;
padding:70px 20px
}
.section h2{
font-size:38px;
margin-bottom:20px;
color:#facc15
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:22px
}

.card{
background:#111827;
padding:24px;
border-radius:18px;
border:1px solid #1f2937
}
.card:hover{
border-color:#22d3ee;
transform:translateY(-3px);
transition:.3s
}

.price{
font-size:28px;
font-weight:700;
margin:10px 0;
color:#22d3ee
}

input,select{
width:100%;
padding:12px;
margin-top:10px;
background:#1e293b;
border:1px solid #334155;
border-radius:10px;
color:#fff
}

.result{
margin-top:20px;
padding:15px;
background:#0f172a;
border-radius:10px;
font-size:22px;
color:#22d3ee
}

.question{
background:#111827;
padding:20px;
border-radius:15px;
margin-top:15px;
border:1px solid #1f2937
}
.option{
background:#1e293b;
padding:10px;
margin-top:8px;
border-radius:10px;
cursor:pointer
}
.option:hover{background:#334155}
.correct{background:#166534!important}
.wrong{background:#991b1b!important}

footer{
text-align:center;
padding:35px 20px;
border-top:1px solid #1f2937;
color:#94a3b8
}

@media(max-width:700px){
.hero h1{font-size:40px}
.section h2{font-size:30px}
.pass{font-size:26px}
}
</style>
</head>
<body>

<header>
<nav>
<div class="logo">DriverPrep Kenya</div>
<div class="menu">
<a href="#tests">NTSA Tests</a>
<a href="#academy">Road Users Academy</a>
<a href="#value">Car Value Checker</a>
<a href="#plans">Plans</a>
<a href="#contact">Contact</a>
</div>
</nav>
</header>

<section class="hero">
<h1>Pass Your NTSA Test <span>As A Pro</span></h1>
<p>Study theory lessons, practice 300+ questions, value vehicles, refresh PSV knowledge, and become a safer road user.</p>
<div class="pass">🔥 Daily Pass KES 49</div>
<a href="#plans" class="btn">Get Started</a>
</section>

<section class="section" id="plans">
<h2>Premium Access Plans</h2>
<div class="grid">

<div class="card">
<h3>Daily Pass</h3>
<div class="price">KES 49</div>
<p>24 hours access to tests, lessons and tools.</p>
</div>

<div class="card">
<h3>PSV Refresher</h3>
<div class="price">KES 200</div>
<p>PSV laws, customer care, safety & compliance.</p>
</div>

<div class="card">
<h3>PDF Books</h3>
<div class="price">KES 150</div>
<p>Download Highway Code, Traffic Act, Signs Book.</p>
</div>

</div>
</section>

<section class="section" id="tests">
<h2>300+ NTSA Practice Tests</h2>
<div id="questions"></div>
</section>

<section class="section" id="academy">
<h2>Road Users Academy</h2>

<div class="grid">

<div class="card">
<h3>Theory Class Self Learning</h3>
<p>Road signs, rules, lane discipline, parking, overtaking, roundabouts, emergencies.</p>
</div>

<div class="card">
<h3>Learn to Drive</h3>
<p>Starting, clutch control, mirrors, reverse parking, hill starts, safe driving habits.</p>
</div>

<div class="card">
<h3>Refresher For Drivers</h3>
<p>Experienced drivers improve on new rules, attitude, accident response, defensive driving.</p>
</div>

<div class="card">
<h3>Customer Service</h3>
<p>Passenger respect, conflict management, professionalism, courtesy, communication.</p>
</div>

<div class="card">
<h3>After Accident or Arrest</h3>
<p>Stay calm, call emergency services, cooperate with police, document scene, contact insurer.</p>
</div>

<div class="card">
<h3>Safari Check Guide</h3>
<p>Tyres, oil, coolant, battery, brakes, lights, mirrors, documents before journey.</p>
</div>

</div>
</section>

<section class="section" id="value">
<h2>Car Value Checker</h2>

<div class="card">

<select id="make">
<option value="">Vehicle Make</option>
<option>Toyota</option>
<option>Nissan</option>
<option>Honda</option>
<option>Mazda</option>
<option>Subaru</option>
<option>Mercedes</option>
<option>BMW</option>
<option>Isuzu</option>
<option>Mitsubishi</option>
<option>TukTuk</option>
<option>Electric Vehicle</option>
</select>

<input type="text" id="model" placeholder="Model">

<select id="year"><option value="">Year</option></select>

<select id="fuel">
<option value="">Fuel Type</option>
<option>Petrol</option>
<option>Diesel</option>
<option>Gas</option>
<option>Electric</option>
<option>Solar Hybrid</option>
</select>

<select id="trans">
<option value="">Transmission</option>
<option>Automatic</option>
<option>Manual</option>
</select>

<select id="colour">
<option value="">Colour</option>
<option>White</option>
<option>Silver</option>
<option>Black</option>
<option>Blue</option>
<option>Red</option>
<option>Green</option>
<option>Yellow</option>
</select>

<input type="number" id="mileage" placeholder="Mileage KM">

<select id="dent">
<option>No Dent</option>
<option>Minor Dent</option>
<option>Major Dent</option>
</select>

<select id="scratch">
<option>No Scratch</option>
<option>Minor Scratch</option>
<option>Major Scratch</option>
</select>

<select id="purpose">
<option>Sale</option>
<option>Insurance</option>
<option>Tax</option>
<option>Loan</option>
<option>Court Bond</option>
<option>Company Asset Update</option>
</select>

<button class="btn" onclick="estimate()">Estimate Value</button>

<div class="result" id="output"></div>

</div>
</section>

<section class="section" id="contact">
<h2>Contact</h2>
<div class="card">
<p>WhatsApp: 0703738707</p>
<p>M-Pesa Paybill: 4095377</p>
<p>Email: info@driverprep.co.ke</p>
</div>
</section>

<footer>
© 2026 DriverPrep Kenya. All rights reserved.
</footer>

<script>
for(let y=2026;y>=1980;y--){
document.getElementById("year").innerHTML += "<option>"+y+"</option>";
}

function estimate(){
let make=document.getElementById("make").value;
let year=parseInt(document.getElementById("year").value)||2020;
let mileage=parseInt(document.getElementById("mileage").value)||0;
let dent=document.getElementById("dent").value;
let scratch=document.getElementById("scratch").value;
let colour=document.getElementById("colour").value;
let purpose=document.getElementById("purpose").value;

let value=1600000-((2026-year)*60000)-(mileage/10000*15000);

if(make=="Mercedes"||make=="BMW") value+=700000;
if(make=="Toyota") value+=120000;
if(make=="TukTuk") value=450000;
if(make=="Electric Vehicle") value+=400000;

if(dent=="Minor Dent") value*=0.95;
if(dent=="Major Dent") value*=0.85;

if(scratch=="Minor Scratch") value*=0.97;
if(scratch=="Major Scratch") value*=0.90;

if(colour=="White"||colour=="Silver") value*=1.03;

if(value<80000)value=80000;

document.getElementById("output").innerHTML=
"Estimated Market Value: KES "+Math.round(value).toLocaleString()+
"<br>Purpose: "+purpose+
"<br>Reason: age, mileage, make, dents, scratches, colour demand.";
}

const qbox=document.getElementById("questions");

for(let i=1;i<=300;i++){
if(i<=10){
qbox.innerHTML+=`
<div class="question">
<b>${i}. What should you do at a STOP sign?</b>
<div class="option" onclick="this.className='option correct'">Stop fully and proceed when safe</div>
<div class="option" onclick="this.className='option wrong'">Speed through</div>
<div class="option" onclick="this.className='option wrong'">Ignore sign</div>
</div>`;
}else{
qbox.innerHTML+=`
<div class="question">
<b>${i}. 🔒 Premium NTSA Question</b>
<p>Unlock all questions with Daily Pass KES 49</p>
</div>`;
}
}
</script>

</body>
</html>
