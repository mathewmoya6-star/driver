<style>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
font-family:Arial,Helvetica,sans-serif;
background:#0a0f1c;
color:#fff;
line-height:1.6
}
header{
background:#111827;
padding:16px 20px;
