// Valuation engine
const brandBaseValues = {
    toyota: 1980000, honda: 1620000, subaru: 1790000, nissan: 1320000,
    mitsubishi: 1380000, volkswagen: 1540000, hyundai: 1180000, mercedes: 2750000,
    bmw: 2450000, ford: 1250000
};

const conditionFactors = {
    excellent: 1.18, verygood: 1.05, good: 0.94, fair: 0.78, needsrepair: 0.60
};

function calculateVehicleValue(make, year, mileage, condition) {
    const baseValue = brandBaseValues[make] || 1650000;
    let age = 2026 - year;
    if (age < 0) age = 0;
    
    // Depreciation
    let yearFactor = age === 0 ? 1.0 : Math.max(0.32, 1 - (age * 0.085));
    let afterYear = baseValue * yearFactor;
    
    // Mileage penalty (KES 2.5 per extra km over 15k/year)
    let expectedKm = Math.max(1, age) * 15000;
    let excessKm = Math.max(0, mileage - expectedKm);
    let mileagePenalty = excessKm * 2.5;
    let afterMileage = Math.max(70000, afterYear - mileagePenalty);
    
    // Condition factor
    let afterCondition = afterMileage * (conditionFactors[condition] || 1.0);
    
    let marketValue = Math.max(60000, Math.round(afterCondition / 1000) * 1000);
    
    return {
        market_value: marketValue,
        forced_sale_value: Math.round(marketValue * 0.72),
        insurance_value: Math.round(marketValue * 0.86),
        net_book_value: Math.round(marketValue * 0.90),
        loan_security_value: Math.round(marketValue * 0.70)
    };
}

// Calculate valuation (no save)
app.post('/api/valuations/calculate', verifyToken, async (req, res) => {
    try {
        const { make, year, mileage, condition } = req.body;
        if (!make || !year || !mileage || !condition) {
            return res.status(400).json({ error: 'Missing required fields' });
        }
        
        const result = calculateVehicleValue(make.toLowerCase(), parseInt(year), parseInt(mileage), condition);
        res.json(result);
    } catch (error) {
        res.status(500).json({ error: 'Calculation failed' });
    }
});

