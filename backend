            .eq('id', authData.user.id)
            .single();
        
        if (profileError) console.warn('Profile fetch warning:', profileError);
        
        // Generate JWT
        const token = jwt.sign({ id: authData.user.id, email }, JWT_SECRET, { expiresIn: '7d' });
        
        res.json({
            success: true,
