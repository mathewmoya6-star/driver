{
  "name": "ExamQuestion",
  "type": "object",
  "properties": {
    "question": {
      "type": "string",
      "description": "The question text"
    },
    "options": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Answer options (4 choices)"
    },
    "correct_answer": {
      "type": "number",
      "description": "Index of the correct answer (0-based)"
    },
    "category": {
      "type": "string",
      "enum": [
        "highway_code",
        "road_signs",
        "traffic_act",
        "defensive_driving",
        "vehicle_maintenance",
        "emergency_response",
        "psv_training"
      ],
      "description": "Question category"
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "easy",
        "medium",
        "hard"
      ],
      "default": "medium"
    },
    "explanation": {
      "type": "string",
      "description": "Explanation of the correct answer"
    }
  },
  "required": [
    "question",
    "options",
    "correct_answer",
    "category"
  ]
}
