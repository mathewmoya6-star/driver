<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MEI DRIVE AFRICA - Admin Portal</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: Arial, sans-serif;
            background: #0a0a0a;
            color: #fff;
        }
        .login-container {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #0a0a0a, #1a1a1a);
        }
        .login-box {
            background: #111;
            border: 1px solid #d4af37;
            border-radius: 20px;
            padding: 40px;
            width: 350px;
            text-align: center;
        }
        .login-box h2 {
            color: #d4af37;
            margin-bottom: 20px;
        }
        .login-box input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            background: #1a1a1a;
            border: 1px solid #333;
            color: #fff;
            border-radius: 8px;
        }
        .login-box button {
            width: 100%;
            padding: 12px;
            background: #d4af37;
            color: #000;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            margin-top: 10px;
        }
        .error {
            color: #f44336;
            margin-top: 10px;
            display: none;
        }
        .dashboard {
            display: none;
        }
        .header {
            background: #111;
            border-bottom: 2px solid #d4af37;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .header h2 {
            color: #d4af37;
        }
        .logout-btn {
            background: #d4af37;
            color: #000;
            border: none;
            padding: 8px 20px;
            border-radius: 5px;
            cursor: pointer;
        }
        .sidebar {
            width: 250px;
            background: #111;
            height: calc(100vh - 70px);
            position: fixed;
            left: 0;
            top: 70px;
            padding: 20px;
        }
        .sidebar button {
            display: block;
            width: 100%;
            padding: 12px;
            margin: 5px 0;
            background: #1a1a1a;
            border: none;
            color: #fff;
            cursor: pointer;
            border-radius: 8px;
            text-align: left;
        }
        .sidebar button:hover, .sidebar button.active {
            background: #d4af37;
            color: #000;
        }
        .content {
            margin-left: 260px;
            padding: 20px;
        }
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            background: #111;
            padding: 20px;
            border-radius: 10px;
            border: 1px solid #333;
        }
        .stat-card h3 {
            color: #d4af37;
            font-size: 14px;
        }
        .stat-card .number {
            font-size: 32px;
            font-weight: bold;
            margin-top: 10px;
        }
        table {
            width: 100%;
            background: #111;
            border-radius: 10px;
            overflow: hidden;
        }
        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #333;
        }
        th {
            background: #1a1a1a;
            color: #d4af37;
        }
        input, textarea, select {
            background: #1a1a1a;
            border: 1px solid #333;
            color: #fff;
            padding: 8px;
            border-radius: 5px;
            width: 100%;
            margin: 5px 0;
        }
        button {
            background: #d4af37;
            color: #000;
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
        }
        .delete-btn {
            background: #c62828;
            color: #fff;
        }
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.9);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        .modal-content {
            background: #111;
            padding: 30px;
            border-radius: 10px;
            width: 500px;
            border: 1px solid #d4af37;
        }
        .section {
            display: none;
        }
        .section.active {
            display: block;
        }
        .btn-add {
            background: #d4af37;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

<!-- Login Page -->
<div id="loginPage" class="login-container">
    <div class="login-box">
        <h2>🔐 MEI DRIVE AFRICA</h2>
        <h3>Admin Login</h3>
        <input type="email" id="loginEmail" placeholder="Email" value="admin@meidrive.com">
        <input type="password" id="loginPassword" placeholder="Password" value="admin123">
        <div id="loginError" class="error">Invalid credentials</div>
        <button onclick="login()">Login</button>
        <p style="margin-top: 15px; color: #888;">Demo: admin@meidrive.com / admin123</p>
    </div>
</div>

<!-- Dashboard -->
<div id="dashboardPage" class="dashboard">
    <div class="header">
        <h2>🚗 MEI DRIVE AFRICA | Admin Portal</h2>
        <button class="logout-btn" onclick="logout()">Logout</button>
    </div>
    <div class="sidebar">
        <button class="active" onclick="showSection('dashboard-section')">📊 Dashboard</button>
        <button onclick="showSection('users-section')">👥 Users</button>
        <button onclick="showSection('questions-section')">❓ Questions</button>
        <button onclick="showSection('courses-section')">📚 Courses</button>
        <button onclick="showSection('settings-section')">⚙️ Settings</button>
    </div>
    <div class="content">
        <!-- Dashboard Section -->
        <div id="dashboard-section" class="section active">
            <h1>Dashboard Overview</h1>
            <div class="stats">
                <div class="stat-card"><h3>Total Users</h3><div class="number" id="statUsers">0</div></div>
                <div class="stat-card"><h3>Total Questions</h3><div class="number" id="statQuestions">0</div></div>
                <div class="stat-card"><h3>Active Learners</h3><div class="number" id="statActive">0</div></div>
                <div class="stat-card"><h3>Completion Rate</h3><div class="number" id="statRate">0%</div></div>
            </div>
            <div style="background:#111; padding:20px; border-radius:10px; margin-top:20px;">
                <h3>Recent Activity</h3>
                <div id="recentActivity">- Admin panel active<br>- Users can register<br>- Add questions to grow bank</div>
            </div>
        </div>

        <!-- Users Section -->
        <div id="users-section" class="section">
            <h1>User Management</h1>
            <button class="btn-add" onclick="openUserModal()">+ Add New User</button>
            <input type="text" id="searchUser" placeholder="Search users..." style="margin-bottom: 20px; width: 300px;">
            <table>
                <thead>
                    <tr><th>ID</th><th>Email</th><th>Name</th><th>Progress</th><th>Actions</th></tr>
                </thead>
                <tbody id="usersList"></tbody>
            </table>
        </div>

        <!-- Questions Section -->
        <div id="questions-section" class="section">
            <h1>Question Bank</h1>
            <button class="btn-add" onclick="openQuestionModal()">+ Add New Question</button>
            <input type="text" id="searchQuestion" placeholder="Search questions..." style="margin-bottom: 20px; width: 300px;">
            <table>
                <thead>
                    <tr><th>ID</th><th>Question</th><th>Options</th><th>Correct</th><th>Actions</th></tr>
                </thead>
                <tbody id="questionsList"></tbody>
            </table>
        </div>

        <!-- Courses Section -->
        <div id="courses-section" class="section">
            <h1>Course Management</h1>
            <div id="coursesList"></div>
        </div>

        <!-- Settings Section -->
        <div id="settings-section" class="section">
            <h1>Admin Settings</h1>
            <div style="background:#111; padding:20px; border-radius:10px;">
                <h3>Change Password</h3>
                <input type="password" id="newPassword" placeholder="New Password" style="width: 300px;">
                <button onclick="changePassword()">Update Password</button>
                <hr style="margin: 20px 0; border-color:#333;">
                <h3>System Settings</h3>
                <label><input type="checkbox" id="maintenanceMode"> Maintenance Mode</label>
                <button onclick="saveSettings()" style="margin-left: 20px;">Save Settings</button>
            </div>
        </div>
    </div>
</div>

<!-- User Modal -->
<div id="userModal" class="modal">
    <div class="modal-content">
        <h3>Add User</h3>
        <input type="email" id="userEmail" placeholder="Email">
        <input type="text" id="userName" placeholder="Full Name">
        <input type="password" id="userPass" placeholder="Password">
        <button onclick="saveUser()">Save</button>
        <button onclick="closeUserModal()" style="background:#333; margin-left:10px;">Cancel</button>
    </div>
</div>

<!-- Question Modal -->
<div id="questionModal" class="modal">
    <div class="modal-content">
        <h3>Add Question</h3>
        <textarea id="qText" placeholder="Question" rows="2"></textarea>
        <input type="text" id="optA" placeholder="Option A">
        <input type="text" id="optB" placeholder="Option B">
        <input type="text" id="optC" placeholder="Option C">
        <input type="text" id="optD" placeholder="Option D">
        <select id="correctOpt">
            <option value="0">Option A</option>
            <option value="1">Option B</option>
            <option value="2">Option C</option>
            <option value="3">Option D</option>
        </select>
        <button onclick="saveQuestion()">Save</button>
        <button onclick="closeQuestionModal()" style="background:#333; margin-left:10px;">Cancel</button>
    </div>
</div>

<script>
    // Data storage
    let users = [];
    let questions = [];
    let isLoggedIn = false;

    // Default questions
    const defaultQuestions = [
        { id: 1, text: "What is the minimum age for a learner driver in Kenya?", options: ["16 years", "17 years", "18 years", "19 years"], correct: 0 },
        { id: 2, text: "What does a red traffic light mean?", options: ["Go", "Slow down", "Stop", "Proceed"], correct: 2 },
        { id: 3, text: "What is the speed limit in urban areas?", options: ["30 km/h", "40 km/h", "50 km/h", "60 km/h"], correct: 2 },
        { id: 4, text: "What should you do at a STOP sign?", options: ["Slow down", "Stop completely", "Continue", "Speed up"], correct: 1 },
        { id: 5, text: "What does a yellow traffic light mean?", options: ["Go faster", "Stop immediately", "Prepare to stop", "Turn around"], correct: 2 }
    ];

    // Load data from localStorage
    function loadData() {
        const storedUsers = localStorage.getItem('admin_users');
        if (storedUsers) {
            users = JSON.parse(storedUsers);
        } else {
            users = [];
        }
        
        const storedQuestions = localStorage.getItem('admin_questions');
        if (storedQuestions) {
            questions = JSON.parse(storedQuestions);
        } else {
            questions = defaultQuestions;
            localStorage.setItem('admin_questions', JSON.stringify(questions));
        }
    }

    function saveUsers() {
        localStorage.setItem('admin_users', JSON.stringify(users));
    }

    function saveQuestions() {
        localStorage.setItem('admin_questions', JSON.stringify(questions));
    }

    // Login
    function login() {
        const email = document.getElementById('loginEmail').value;
        const password = document.getElementById('loginPassword').value;
        
        if (email === 'admin@meidrive.com' && password === 'admin123') {
            isLoggedIn = true;
            localStorage.setItem('admin_logged_in', 'true');
            document.getElementById('loginPage').style.display = 'none';
            document.getElementById('dashboardPage').style.display = 'block';
            loadData();
            refreshDashboard();
            refreshUsers();
            refreshQuestions();
        } else {
            document.getElementById('loginError').style.display = 'block';
        }
    }

    function logout() {
        isLoggedIn = false;
        localStorage.removeItem('admin_logged_in');
        document.getElementById('loginPage').style.display = 'flex';
        document.getElementById('dashboardPage').style.display = 'none';
    }

    function checkSession() {
        if (localStorage.getItem('admin_logged_in') === 'true') {
            document.getElementById('loginPage').style.display = 'none';
            document.getElementById('dashboardPage').style.display = 'block';
            loadData();
            refreshDashboard();
            refreshUsers();
            refreshQuestions();
        }
    }

    // Navigation
    function showSection(sectionId) {
        document.querySelectorAll('.section').forEach(section => {
            section.classList.remove('active');
        });
        document.getElementById(sectionId).classList.add('active');
        
        if (sectionId === 'dashboard-section') refreshDashboard();
        if (sectionId === 'users-section') refreshUsers();
        if (sectionId === 'questions-section') refreshQuestions();
    }

    // Refresh Dashboard
    function refreshDashboard() {
        document.getElementById('statUsers').innerHTML = users.length;
        document.getElementById('statQuestions').innerHTML = questions.length;
        const active = users.filter(u => u.progress > 0).length;
        document.getElementById('statActive').innerHTML = active;
        const rate = users.length ? Math.round((active / users.length) * 100) : 0;
        document.getElementById('statRate').innerHTML = rate + '%';
    }

    // Refresh Users
    function refreshUsers() {
        const tbody = document.getElementById('usersList');
        if (users.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" style="text-align:center">No users yet</td></tr>';
            return;
        }
        tbody.innerHTML = users.map(user => `
            <tr>
                <td>${user.id}</td>
                <td>${user.email}</td>
                <td>${user.name || '-'}</td>
                <td>${user.progress || 0}%</td>
                <td><button class="delete-btn" onclick="deleteUser(${user.id})">Delete</button></td>
            </tr>
        `).join('');
    }

    function searchUsers() {
        const search = document.getElementById('searchUser').value.toLowerCase();
        const filtered = users.filter(u => u.email.toLowerCase().includes(search));
        document.getElementById('usersList').innerHTML = filtered.map(user => `
            <tr><td>${user.id}</td><td>${user.email}</td><td>${user.name || '-'}</td><td>${user.progress || 0}%</td>
            <td><button class="delete-btn" onclick="deleteUser(${user.id})">Delete</button></td></tr>
        `).join('');
    }

    function deleteUser(id) {
        if (confirm('Delete this user?')) {
            users = users.filter(u => u.id !== id);
            saveUsers();
            refreshUsers();
            refreshDashboard();
        }
    }

    function openUserModal() {
        document.getElementById('userEmail').value = '';
        document.getElementById('userName').value = '';
        document.getElementById('userPass').value = '';
        document.getElementById('userModal').style.display = 'flex';
    }

    function closeUserModal() {
        document.getElementById('userModal').style.display = 'none';
    }

    function saveUser() {
        const email = document.getElementById('userEmail').value;
        const name = document.getElementById('userName').value;
        const password = document.getElementById('userPass').value;
        
        if (email && password) {
            const newUser = {
                id: Date.now(),
                email: email,
                name: name,
                password: btoa(password),
                progress: 0
            };
            users.push(newUser);
            saveUsers();
            closeUserModal();
            refreshUsers();
            refreshDashboard();
            alert('User added!');
        } else {
            alert('Please fill email and password');
        }
    }

    // Refresh Questions
    function refreshQuestions() {
        const tbody = document.getElementById('questionsList');
        tbody.innerHTML = questions.map(q => `
            <tr>
                <td>${q.id}</td>
                <td>${q.text}</td>
                <td>${q.options.join(', ')}</td>
                <td>${String.fromCharCode(65 + q.correct)}</td>
                <td><button class="delete-btn" onclick="deleteQuestion(${q.id})">Delete</button></td>
            </tr>
        `).join('');
    }

    function searchQuestions() {
        const search = document.getElementById('searchQuestion').value.toLowerCase();
        const filtered = questions.filter(q => q.text.toLowerCase().includes(search));
        document.getElementById('questionsList').innerHTML = filtered.map(q => `
            <tr><td>${q.id}</td><td>${q.text}</td><td>${q.options.join(', ')}</td>
            <td>${String.fromCharCode(65 + q.correct)}</td>
            <td><button class="delete-btn" onclick="deleteQuestion(${q.id})">Delete</button></td></tr>
        `).join('');
    }

    function deleteQuestion(id) {
        if (confirm('Delete this question?')) {
            questions = questions.filter(q => q.id !== id);
            saveQuestions();
            refreshQuestions();
            refreshDashboard();
        }
    }

    function openQuestionModal() {
        document.getElementById('qText').value = '';
        document.getElementById('optA').value = '';
        document.getElementById('optB').value = '';
        document.getElementById('optC').value = '';
        document.getElementById('optD').value = '';
        document.getElementById('questionModal').style.display = 'flex';
    }

    function closeQuestionModal() {
        document.getElementById('questionModal').style.display = 'none';
    }

    function saveQuestion() {
        const text = document.getElementById('qText').value;
        const options = [
            document.getElementById('optA').value,
            document.getElementById('optB').value,
            document.getElementById('optC').value,
            document.getElementById('optD').value
        ];
        const correct = parseInt(document.getElementById('correctOpt').value);
        
        if (text && options.every(o => o)) {
            const newQuestion = {
                id: Date.now(),
                text: text,
                options: options,
                correct: correct
            };
            questions.push(newQuestion);
            saveQuestions();
            closeQuestionModal();
            refreshQuestions();
            refreshDashboard();
            alert('Question added!');
        } else {
            alert('Please fill all fields');
        }
    }

    function changePassword() {
        const newPass = document.getElementById('newPassword').value;
        if (newPass) {
            alert('Password changed successfully!');
            document.getElementById('newPassword').value = '';
        }
    }

    function saveSettings() {
        alert('Settings saved!');
    }

    // Search event listeners
    document.addEventListener('DOMContentLoaded', function() {
        const userSearch = document.getElementById('searchUser');
        if (userSearch) userSearch.addEventListener('keyup', searchUsers);
        
        const questionSearch = document.getElementById('searchQuestion');
        if (questionSearch) questionSearch.addEventListener('keyup', searchQuestions);
    });

    // Modal close on outside click
    window.onclick = function(e) {
        if (e.target.classList.contains('modal')) {
            e.target.style.display = 'none';
        }
    }

    // Initialize
    checkSession();
</script>
</body>
</html>