<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MEI DRIVE AFRICA - Admin Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #0a0a0a;
            color: #fff;
            overflow-x: hidden;
        }

        /* Admin Header */
        .admin-header {
            background: linear-gradient(135deg, #0a0a0a, #1a1a1a);
            border-bottom: 2px solid #d4af37;
            padding: 16px 24px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .admin-header-content {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
        }

        .logo {
            color: #d4af37;
            font-size: 20px;
            font-weight: 800;
        }

        .logo span {
            color: #fff;
            font-weight: 400;
        }

        .admin-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .admin-badge {
            background: #d4af37;
            color: #000;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .logout-btn {
            background: transparent;
            border: 1px solid #d4af37;
            color: #d4af37;
            padding: 6px 16px;
            border-radius: 20px;
            cursor: pointer;
            transition: 0.2s;
        }

        .logout-btn:hover {
            background: #d4af37;
            color: #000;
        }

        /* Dashboard Layout */
        .dashboard-container {
            display: flex;
            min-height: calc(100vh - 70px);
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background: #0f0f0f;
            border-right: 1px solid #222;
            padding: 24px 0;
            position: sticky;
            top: 70px;
            height: calc(100vh - 70px);
            overflow-y: auto;
        }

        .sidebar-menu {
            list-style: none;
        }

        .sidebar-item {
            padding: 12px 24px;
            cursor: pointer;
            transition: 0.2s;
            border-left: 3px solid transparent;
        }

        .sidebar-item:hover {
            background: #1a1a1a;
        }

        .sidebar-item.active {
            background: #1a1a1a;
            border-left-color: #d4af37;
            color: #d4af37;
        }

        .sidebar-item i {
            margin-right: 12px;
        }

        /* Main Content */
        .main-content {
            flex: 1;
            padding: 24px;
            overflow-y: auto;
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }

        .stat-card {
            background: #111;
            border: 1px solid #222;
            border-radius: 16px;
            padding: 20px;
            transition: 0.2s;
        }

        .stat-card:hover {
            border-color: #d4af37;
        }

        .stat-title {
            color: #888;
            font-size: 13px;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 800;
            color: #d4af37;
        }

        /* Tables */
        .data-table {
            width: 100%;
            background: #111;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid #222;
        }

        .data-table th,
        .data-table td {
            padding: 14px 16px;
            text-align: left;
            border-bottom: 1px solid #222;
        }

        .data-table th {
            background: #1a1a1a;
            color: #d4af37;
            font-weight: 600;
        }

        .data-table tr:hover {
            background: #1a1a1a;
        }

        /* Buttons */
        .btn-primary {
            background: #d4af37;
            color: #000;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.2s;
        }

        .btn-primary:hover {
            background: #c4a027;
            transform: translateY(-1px);
        }

        .btn-danger {
            background: #c62828;
            color: #fff;
            border: none;
            padding: 6px 12px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
        }

        .btn-danger:hover {
            background: #b71c1c;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: #111;
            border: 1px solid #d4af37;
            border-radius: 20px;
            padding: 32px;
            max-width: 500px;
            width: 90%;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .close-modal {
            cursor: pointer;
            font-size: 28px;
            color: #d4af37;
        }

        input, select, textarea {
            width: 100%;
            padding: 12px;
            background: #1a1a1a;
            border: 1px solid #333;
            color: #fff;
            border-radius: 8px;
            margin: 8px 0 16px;
        }

        /* Login Page */
        .login-container {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #0a0a0a, #1a1a1a);
        }

        .login-box {
            background: #111;
            border: 1px solid #d4af37;
            border-radius: 24px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
        }

        .login-box h2 {
            color: #d4af37;
            margin-bottom: 24px;
            text-align: center;
        }

        .error-msg {
            color: #f44336;
            font-size: 12px;
            margin-top: 8px;
            display: none;
        }

        /* Section visibility */
        .section {
            display: none;
        }

        .section.active {
            display: block;
        }

        .search-bar {
            margin-bottom: 20px;
            display: flex;
            gap: 12px;
        }

        .search-bar input {
            flex: 1;
            margin: 0;
        }

        @media (max-width: 768px) {
            .sidebar {
                width: 70px;
            }
            .sidebar-item span {
                display: none;
            }
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

<!-- Login Section -->
<div id="loginSection" class="login-container">
    <div class="login-box">
        <h2>🔐 MEI DRIVE AFRICA</h2>
        <h3 style="text-align:center; margin-bottom:20px; font-size:16px;">Admin Login</h3>
        <input type="email" id="adminEmail" placeholder="Admin Email" value="admin@meidrive.com">
        <input type="password" id="adminPassword" placeholder="Password" value="admin123">
        <div id="loginError" class="error-msg">Invalid credentials</div>
        <button class="btn-primary" style="width:100%" onclick="adminLogin()">Login →</button>
        <p style="text-align:center; margin-top:16px; color:#888; font-size:12px;">Demo: admin@meidrive.com / admin123</p>
    </div>
</div>

<!-- Admin Dashboard (Hidden by default) -->
<div id="dashboardSection" style="display:none">
    <div class="admin-header">
        <div class="admin-header-content">
            <div class="logo">MEI DRIVE <span>AFRICA</span> | ADMIN PORTAL</div>
            <div class="admin-info">
                <span class="admin-badge" id="adminName">Admin</span>
                <button class="logout-btn" onclick="adminLogout()">Logout</button>
            </div>
        </div>
    </div>

    <div class="dashboard-container">
        <!-- Sidebar -->
        <div class="sidebar">
            <ul class="sidebar-menu">
                <li class="sidebar-item active" onclick="showSection('dashboard')">
                    📊 <span> Dashboard</span>
                </li>
                <li class="sidebar-item" onclick="showSection('users')">
                    👥 <span> Users</span>
                </li>
                <li class="sidebar-item" onclick="showSection('questions')">
                    ❓ <span> Questions Bank</span>
                </li>
                <li class="sidebar-item" onclick="showSection('content')">
                    📚 <span> Content Library</span>
                </li>
                <li class="sidebar-item" onclick="showSection('analytics')">
                    📈 <span> Analytics</span>
                </li>
                <li class="sidebar-item" onclick="showSection('settings')">
                    ⚙️ <span> Settings</span>
                </li>
            </ul>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Dashboard Section -->
            <div id="dashboard" class="section active">
                <h1 style="margin-bottom: 24px;">📊 Dashboard Overview</h1>
                <div class="stats-grid">
                    <div class="stat-card"><div class="stat-title">Total Users</div><div class="stat-value" id="totalUsers">0</div></div>
                    <div class="stat-card"><div class="stat-title">Active Learners</div><div class="stat-value" id="activeLearners">0</div></div>
                    <div class="stat-card"><div class="stat-title">Questions Answered</div><div class="stat-value" id="totalAnswers">0</div></div>
                    <div class="stat-card"><div class="stat-title">Completion Rate</div><div class="stat-value" id="completionRate">0%</div></div>
                </div>
                <div class="stat-card"><h3>📈 Recent Activity</h3><div id="recentActivity">Loading...</div></div>
            </div>

            <!-- Users Section -->
            <div id="users" class="section">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h1>👥 User Management</h1>
                    <button class="btn-primary" onclick="openUserModal()">+ Add User</button>
                </div>
                <div class="search-bar"><input type="text" id="userSearch" placeholder="Search users..." onkeyup="searchUsers()"></div>
                <table class="data-table" id="usersTable"><thead><tr><th>ID</th><th>Email</th><th>Name</th><th>Progress</th><th>Actions</th></tr></thead><tbody id="usersList"></tbody></table>
            </div>

            <!-- Questions Section -->
            <div id="questions" class="section">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h1>❓ Question Bank</h1>
                    <button class="btn-primary" onclick="openQuestionModal()">+ Add Question</button>
                </div>
                <div class="search-bar"><input type="text" id="questionSearch" placeholder="Search questions..." onkeyup="searchQuestions()"></div>
                <table class="data-table"><thead><tr><th>ID</th><th>Question</th><th>Options</th><th>Correct</th><th>Actions</th></tr></thead><tbody id="questionsList"></tbody></table>
            </div>

            <!-- Content Library Section -->
            <div id="content" class="section">
                <h1>📚 Content Library</h1>
                <div class="stats-grid" id="libraryStats"></div>
                <div id="contentList"></div>
            </div>

            <!-- Analytics Section -->
            <div id="analytics" class="section">
                <h1>📈 Analytics & Reports</h1>
                <div class="stats-grid">
                    <div class="stat-card"><div class="stat-title">Most Active Day</div><div class="stat-value" id="peakDay">-</div></div>
                    <div class="stat-card"><div class="stat-title">Top Performing Module</div><div class="stat-value" id="topModule">-</div></div>
                </div>
                <div class="stat-card"><h3>📊 User Progress Distribution</h3><div id="progressChart"></div></div>
            </div>

            <!-- Settings Section -->
            <div id="settings" class="section">
                <h1>⚙️ Settings</h1>
                <div class="stat-card"><h3>Admin Profile</h3><input type="text" id="adminFullName" placeholder="Full Name"><input type="email" id="adminEmailSettings" placeholder="Email"><button class="btn-primary" onclick="updateAdminProfile()">Update Profile</button></div>
                <div class="stat-card"><h3>Change Password</h3><input type="password" id="newPassword" placeholder="New Password"><button class="btn-primary" onclick="changeAdminPassword()">Change Password</button></div>
                <div class="stat-card"><h3>System Settings</h3><label><input type="checkbox" id="maintenanceMode"> Maintenance Mode</label><br><br><button class="btn-primary" onclick="saveSettings()">Save Settings</button></div>
            </div>
        </div>
    </div>
</div>

<!-- Modals -->
<div id="userModal" class="modal"><div class="modal-content"><div class="modal-header"><h3>Add/Edit User</h3><span class="close-modal" onclick="closeUserModal()">&times;</span></div><input type="email" id="userEmail" placeholder="Email"><input type="text" id="userName" placeholder="Full Name"><input type="password" id="userPassword" placeholder="Password"><button class="btn-primary" onclick="saveUser()">Save User</button></div></div>

<div id="questionModal" class="modal"><div class="modal-content"><div class="modal-header"><h3>Add/Edit Question</h3><span class="close-modal" onclick="closeQuestionModal()">&times;</span></div><input type="text" id="questionText" placeholder="Question"><input type="text" id="optionA" placeholder="Option A"><input type="text" id="optionB" placeholder="Option B"><input type="text" id="optionC" placeholder="Option C"><input type="text" id="optionD" placeholder="Option D"><select id="correctAnswer"><option value="0">A</option><option value="1">B</option><option value="2">C</option><option value="3">D</option></select><button class="btn-primary" onclick="saveQuestion()">Save Question</button></div></div>

<script>
    // Admin credentials
    let isAdminLoggedIn = false;
    let users = [];
    let questions = [];

    // Admin Login
    function adminLogin() {
        const email = document.getElementById('adminEmail').value;
        const password = document.getElementById('adminPassword').value;
        
        if (email === 'admin@meidrive.com' && password === 'admin123') {
            isAdminLoggedIn = true;
            localStorage.setItem('adminLoggedIn', 'true');
            document.getElementById('loginSection').style.display = 'none';
            document.getElementById('dashboardSection').style.display = 'block';
            loadDashboardData();
            loadUsers();
            loadQuestions();
        } else {
            document.getElementById('loginError').style.display = 'block';
        }
    }

    function adminLogout() {
        isAdminLoggedIn = false;
        localStorage.removeItem('adminLoggedIn');
        document.getElementById('loginSection').style.display = 'flex';
        document.getElementById('dashboardSection').style.display = 'none';
    }

    // Check session
    function checkSession() {
        if (localStorage.getItem('adminLoggedIn') === 'true') {
            document.getElementById('loginSection').style.display = 'none';
            document.getElementById('dashboardSection').style.display = 'block';
            loadDashboardData();
            loadUsers();
            loadQuestions();
        }
    }

    // Navigation
    function showSection(sectionId) {
        document.querySelectorAll('.section').forEach(section => {
            section.classList.remove('active');
        });
        document.getElementById(sectionId).classList.add('active');
        
        document.querySelectorAll('.sidebar-item').forEach(item => {
            item.classList.remove('active');
        });
        event.target.closest('.sidebar-item').classList.add('active');
        
        if (sectionId === 'dashboard') loadDashboardData();
        if (sectionId === 'users') loadUsers();
        if (sectionId === 'questions') loadQuestions();
    }

    // Load Dashboard Data
    function loadDashboardData() {
        const totalUsers = users.length;
        const activeLearners = users.filter(u => u.progress > 0).length;
        document.getElementById('totalUsers').innerHTML = totalUsers;
        document.getElementById('activeLearners').innerHTML = activeLearners;
        document.getElementById('totalAnswers').innerHTML = '0';
        document.getElementById('completionRate').innerHTML = totalUsers ? Math.round((activeLearners/totalUsers)*100) + '%' : '0%';
        
        document.getElementById('recentActivity').innerHTML = '<p>✅ Admin panel active</p><p>📊 Users can register and learn</p><p>🎯 Add questions to grow the bank</p>';
    }

    // Load Users
    function loadUsers() {
        const stored = localStorage.getItem('mei_users');
        if (stored) users = JSON.parse(stored);
        
        const tbody = document.getElementById('usersList');
        if (users.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" style="text-align:center">No users yet</td></tr>';
            return;
        }
        
        tbody.innerHTML = users.map(user => `
            <tr>
                <td>${user.id}</td>
                <td>${user.email}</td>
                <td>${user.name || '-'}</td>
                <td>${user.progress || 0}%</td>
                <td><button class="btn-danger" onclick="deleteUser(${user.id})">Delete</button></td>
            </tr>
        `).join('');
        document.getElementById('totalUsers').innerHTML = users.length;
    }

    function searchUsers() {
        const search = document.getElementById('userSearch').value.toLowerCase();
        const filtered = users.filter(u => u.email.toLowerCase().includes(search) || (u.name && u.name.toLowerCase().includes(search)));
        document.getElementById('usersList').innerHTML = filtered.map(user => `<tr><td>${user.id}</td><td>${user.email}</td><td>${user.name || '-'}</td><td>${user.progress || 0}%</td><td><button class="btn-danger" onclick="deleteUser(${user.id})">Delete</button></td></tr>`).join('');
    }

    function deleteUser(id) {
        users = users.filter(u => u.id !== id);
        localStorage.setItem('mei_users', JSON.stringify(users));
        loadUsers();
        loadDashboardData();
    }

    function openUserModal() {
        document.getElementById('userEmail').value = '';
        document.getElementById('userName').value = '';
        document.getElementById('userPassword').value = '';
        document.getElementById('userModal').style.display = 'flex';
    }

    function closeUserModal() {
        document.getElementById('userModal').style.display = 'none';
    }

    function saveUser() {
        const email = document.getElementById('userEmail').value;
        const name = document.getElementById('userName').value;
        const password = document.getElementById('userPassword').value;
        
        if (email && password) {
            const newUser = {
                id: Date.now(),
                email: email,
                name: name,
                password: btoa(password),
                progress: 0,
                createdAt: new Date()
            };
            users.push(newUser);
            localStorage.setItem('mei_users', JSON.stringify(users));
            closeUserModal();
            loadUsers();
            loadDashboardData();
            alert('User added successfully!');
        } else {
            alert('Please fill all fields');
        }
    }

    // Load Questions
    function loadQuestions() {
        const stored = localStorage.getItem('mei_questions');
        if (stored) questions = JSON.parse(stored);
        else {
            questions = [
                { id: 1, text: "What is the minimum age for a learner driver in Kenya?", options: ["16 years", "17 years", "18 years", "19 years"], correct: 0 },
                { id: 2, text: "What does a red traffic light mean?", options: ["Go", "Slow down", "Stop", "Proceed with caution"], correct: 2 },
                { id: 3, text: "What is the speed limit in urban areas?", options: ["30 km/h", "40 km/h", "50 km/h", "60 km/h"], correct: 2 }
            ];
            localStorage.setItem('mei_questions', JSON.stringify(questions));
        }
        
        const tbody = document.getElementById('questionsList');
        tbody.innerHTML = questions.map(q => `
            <tr>
                <td>${q.id}</td>
                <td>${q.text}</td>
                <td>${q.options.join(', ')}</td>
                <td>${String.fromCharCode(65 + q.correct)}</td>
                <td><button class="btn-danger" onclick="deleteQuestion(${q.id})">Delete</button></td>
            </tr>
        `).join('');
    }

    function searchQuestions() {
        const search = document.getElementById('questionSearch').value.toLowerCase();
        const filtered = questions.filter(q => q.text.toLowerCase().includes(search));
        document.getElementById('questionsList').innerHTML = filtered.map(q => `<tr><td>${q.id}</td><td>${q.text}</td><td>${q.options.join(', ')}</td><td>${String.fromCharCode(65 + q.correct)}</td><td><button class="btn-danger" onclick="deleteQuestion(${q.id})">Delete</button></td></tr>`).join('');
    }

    function deleteQuestion(id) {
        questions = questions.filter(q => q.id !== id);
        localStorage.setItem('mei_questions', JSON.stringify(questions));
        loadQuestions();
    }

    function openQuestionModal() {
        document.getElementById('questionText').value = '';
        document.getElementById('optionA').value = '';
        document.getElementById('optionB').value = '';
        document.getElementById('optionC').value = '';
        document.getElementById('optionD').value = '';
        document.getElementById('questionModal').style.display = 'flex';
    }

    function closeQuestionModal() {
        document.getElementById('questionModal').style.display = 'none';
    }

    function saveQuestion() {
        const text = document.getElementById('questionText').value;
        const options = [
            document.getElementById('optionA').value,
            document.getElementById('optionB').value,
            document.getElementById('optionC').value,
            document.getElementById('optionD').value
        ];
        const correct = parseInt(document.getElementById('correctAnswer').value);
        
        if (text && options.every(o => o)) {
            const newQuestion = {
                id: Date.now(),
                text: text,
                options: options,
                correct: correct
            };
            questions.push(newQuestion);
            localStorage.setItem('mei_questions', JSON.stringify(questions));
            closeQuestionModal();
            loadQuestions();
            alert('Question added!');
        } else {
            alert('Please fill all fields');
        }
    }

    function updateAdminProfile() {
        alert('Profile updated (demo)');
    }

    function changeAdminPassword() {
        alert('Password changed (demo)');
    }

    function saveSettings() {
        alert('Settings saved (demo)');
    }

    // Modal close on click outside
    window.onclick = function(e) {
        if (e.target.classList.contains('modal')) {
            e.target.style.display = 'none';
        }
    }

    // Initialize
    checkSession();
</script>
</body>
</html>