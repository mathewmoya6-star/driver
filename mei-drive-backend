const MPESA_ENVIRONMENT = process.env.MPESA_ENVIRONMENT || 'sandbox';

// M-PESA API endpoints
const MPESA_API_URL = MPESA_ENVIRONMENT === 'production' 
    ? 'https://api.safaricom.co.ke'
    : 'https://sandbox.safaricom.co.ke';

let mpesaAccessToken = null;
let tokenExpiry = null;

async function getMpesaAccessToken() {
    if (mpesaAccessToken && tokenExpiry && tokenExpiry > Date.now()) {
        return mpesaAccessToken;
    }
    
    const auth = Buffer.from(`${MPESA_CONSUMER_KEY}:${MPESA_CONSUMER_SECRET}`).toString('base64');
    try {
        const response = await axios.get(`${MPESA_API_URL}/oauth/v1/generate?grant_type=client_credentials`, {
            headers: { Authorization: `Basic ${auth}` }
        });
        mpesaAccessToken = response.data.access_token;
        tokenExpiry = Date.now() + (response.data.expires_in * 1000) - 60000;
        return mpesaAccessToken;
    } catch (error) {
        console.error('M-PESA token error:', error.response?.data || error.message);
        throw new Error('Failed to get M-PESA token');
    }
}

// Generate password for STK Push
function generatePassword(shortcode, passkey, timestamp) {
    const str = `${shortcode}${passkey}${timestamp}`;
    return Buffer.from(str).toString('base64');
}

// STK Push (Lipa Na M-PESA Online)
app.post('/api/payments/mpesa/stkpush', verifyToken, async (req, res) => {
    try {
        const { phoneNumber, amount, accountReference = 'MEIDRIVE', transactionDesc = 'MEI Drive Africa Payment' } = req.body;
        
        // Validate amount
        const paymentAmount = parseFloat(amount);
        if (isNaN(paymentAmount) || paymentAmount < 10 || paymentAmount > 150000) {
            return res.status(400).json({ error: 'Amount must be between KES 10 and KES 150,000.' });
        }
        
        // Format phone number (254XXXXXXXXX)
        let formattedPhone = phoneNumber.replace(/\D/g, '');
        if (formattedPhone.startsWith('0')) formattedPhone = '254' + formattedPhone.substring(1);
        if (!formattedPhone.startsWith('254')) formattedPhone = '254' + formattedPhone;
        
        const accessToken = await getMpesaAccessToken();
        const timestamp = new Date().toISOString().replace(/[^0-9]/g, '').slice(0, 14);
        const password = generatePassword(MPESA_PAYBILL_NUMBER, MPESA_PASSKEY, timestamp);
        
        const response = await axios.post(`${MPESA_API_URL}/mpesa/stkpush/v1/processrequest`, {
            BusinessShortCode: MPESA_PAYBILL_NUMBER,
            Password: password,
            Timestamp: timestamp,
            TransactionType: 'CustomerPayBillOnline',
            Amount: Math.round(paymentAmount),
            PartyA: formattedPhone,
            PartyB: MPESA_PAYBILL_NUMBER,
            PhoneNumber: formattedPhone,
            CallBackURL: `${process.env.CALLBACK_URL || 'https://api.meidrive.africa'}/api/payments/mpesa/callback`,
            AccountReference: accountReference,
            TransactionDesc: transactionDesc.substring(0, 36)
        }, {
            headers: { Authorization: `Bearer ${accessToken}` }
        });
        
        // Store pending transaction
        await supabase.from('payments').insert({
            user_id: req.user.id,
            transaction_id: response.data.CheckoutRequestID,
            amount: paymentAmount,
            status: 'pending',
            payment_method: 'mpesa',
            paybill_number: MPESA_PAYBILL_NUMBER,
            phone_number: encrypt(formattedPhone),
            created_at: new Date()
        });
        
        await auditLog(req.user.id, 'PAYMENT_INITIATED', { amount: paymentAmount, transaction_id: response.data.CheckoutRequestID }, req.ip, req.headers['user-agent']);
        
        res.json({
            success: true,
            checkoutRequestID: response.data.CheckoutRequestID,
            responseCode: response.data.ResponseCode,
            responseDescription: response.data.ResponseDescription
        });
    } catch (error) {
        console.error('M-PESA STK Push error:', error.response?.data || error.message);
        res.status(500).json({ error: 'Payment initiation failed. Please try again.' });
    }
});

// M-PESA Callback (webhook - must be public endpoint)
app.post('/api/payments/mpesa/callback', async (req, res) => {
    try {
        const { Body } = req.body;
        if (!Body || !Body.stkCallback) {
            return res.status(200).json({ ResultCode: 0, ResultDesc: 'No callback data' });
        }
        
        const { ResultCode, ResultDesc, CheckoutRequestID, CallbackMetadata } = Body.stkCallback;
        
        // Update payment status
        const { data: payment } = await supabase
            .from('payments')
            .update({
                status: ResultCode === 0 ? 'completed' : 'failed',
                result_code: ResultCode,
                result_desc: ResultDesc,
                mpesa_receipt: CallbackMetadata?.Item?.find(i => i.Name === 'MpesaReceiptNumber')?.Value,
                completed_at: new Date()
            })
            .eq('transaction_id', CheckoutRequestID)
            .select()
            .single();
        
        if (ResultCode === 0 && payment) {
            // Activate subscription/training access based on amount
            await activateSubscription(payment.user_id, payment.amount);
            await auditLog(payment.user_id, 'PAYMENT_COMPLETED', { amount: payment.amount, receipt: CallbackMetadata?.Item?.find(i => i.Name === 'MpesaReceiptNumber')?.Value }, req.ip, req.headers['user-agent']);
        }
        
        res.status(200).json({ ResultCode: 0, ResultDesc: 'Success' });
    } catch (error) {
        console.error('M-PESA callback error:', error);
        res.status(200).json({ ResultCode: 0, ResultDesc: 'Processed' });
    }
});

