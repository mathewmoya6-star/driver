app.post('/api/auth/register', async (req, res) => {
    try {
        const { email, password, full_name, phone_number, license_class = 'B' } = req.body;
        
        if (!email || !password || !full_name) {
            return res.status(400).json({ error: 'Email, password, and full name are required.' });
        }
        if (password.length < 8) {
            return res.status(400).json({ error: 'Password must be at least 8 characters.' });
        }
        if (!/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)/.test(password)) {
            return res.status(400).json({ error: 'Password must contain uppercase, lowercase, and number.' });
        }
        
        const { data: authData, error: authError } = await supabase.auth.signUp({
            email,
            password,
            options: { data: { full_name, phone_number } }
        });
        
        if (authError) return res.status(400).json({ error: authError.message });
        
        await supabase.from('profiles').upsert({
            id: authData.user.id,
            full_name,
            phone_number: encrypt(phone_number),
            license_class
        });
        
        const token = generateToken(authData.user.id, email);
        const refreshToken = generateRefreshToken(authData.user.id);
        
        await auditLog(authData.user.id, 'REGISTER', { email }, req.ip, req.headers['user-agent']);
        
        res.status(201).json({ success: true, token, refreshToken, user: { id: authData.user.id, email, full_name, license_class } });
    } catch (error) {
        console.error('Registration error:', error);
        res.status(500).json({ error: 'Server error during registration.' });
    }
});

app.post('/api/auth/login', async (req, res) => {
    try {
        const { email, password } = req.body;
        if (!email || !password) return res.status(400).json({ error: 'Email and password are required.' });
        
        const { data: authData, error: authError } = await supabase.auth.signInWithPassword({ email, password });
        if (authError) return res.status(401).json({ error: 'Invalid email or password.' });
        
        const { data: profile } = await supabase.from('profiles').select('*').eq('id', authData.user.id).single();
        
        const token = generateToken(authData.user.id, email);
        const refreshToken = generateRefreshToken(authData.user.id);
        
        await auditLog(authData.user.id, 'LOGIN', { email }, req.ip, req.headers['user-agent']);
        
        res.json({ success: true, token, refreshToken, user: { id: authData.user.id, email, full_name: profile?.full_name, phone_number: profile?.phone_number ? decrypt(profile.phone_number) : null, license_class: profile?.license_class } });
    } catch (error) {
        console.error('Login error:', error);
        res.status(500).json({ error: 'Server error during login.' });
    }
});

