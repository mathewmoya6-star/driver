// VEHICLE VALUATION ENGINE
// ============================================
const brandBaseValues = {
    toyota: 1980000, honda: 1620000, subaru: 1790000, nissan: 1320000,
    mitsubishi: 1380000, volkswagen: 1540000, hyundai: 1180000, mercedes: 2750000,
    bmw: 2450000, ford: 1250000, mazda: 1350000, suzuki: 950000
};

const conditionFactors = {
    excellent: 1.18, verygood: 1.05, good: 0.94, fair: 0.78, needsrepair: 0.60
};

const colourBonusMap = { standard: 0, premium: 24000, rare: 52000 };
const extraMap = { "0": 0, "1": 38000, "-1": -85000 };

function getYearFactor(year) {
    const currentYear = 2026;
    let age = currentYear - year;
    if (age < 0) age = 0;
    if (age === 0) return 1.0;
    let factor = 1.0;
    for (let i = 1; i <= age; i++) {
        if (i === 1) factor *= 0.87;
        else if (i === 2) factor *= 0.91;
        else factor *= 0.925;
    }
    return Math.max(0.32, Math.min(1.0, factor));
}

function calcMileagePenalty(mileage, year) {
    let age = Math.max(1, 2026 - year);
    let expectedKm = age * 15000;
    let excess = Math.max(0, mileage - expectedKm);
    let penalty = excess * 2.4;
    return Math.min(400000, penalty);
}

function calculateVehicleValue(params) {
    const { make, year, mileage, condition, color, extraHistory } = params;
    const baseValue = brandBaseValues[make] || 1650000;
    
    const yearFactor = getYearFactor(year);
    let afterYear = baseValue * yearFactor;
    const mileageDeduction = calcMileagePenalty(mileage, year);
    let afterMileage = Math.max(70000, afterYear - mileageDeduction);
    const condMult = conditionFactors[condition];
    let afterCondition = afterMileage * condMult;
    const colourBonus = colourBonusMap[color];
    const extraAdjustment = extraMap[extraHistory];
    
    let marketValue = afterCondition + colourBonus + extraAdjustment;
    marketValue = Math.max(60000, Math.round(marketValue / 1000) * 1000);
    
    return {
        market_value: marketValue,
        forced_sale_value: Math.round(marketValue * 0.72),
        insurance_value: Math.round(marketValue * 0.86),
        net_book_value: Math.round(marketValue * 0.90),
        loan_security_value: Math.round(marketValue * 0.70),
        scrap_value: Math.max(45000, Math.round(marketValue * 0.12))
    };
}

