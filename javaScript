// DRIVERPREP KENYA PREMIUM SCRIPT

document.addEventListener("DOMContentLoaded", function () {
    
    console.log("DriverPrep Kenya Loaded");

    // Smooth scroll links
    const links = document.querySelectorAll('a[href^="#"]');

    links.forEach(link => {
        link.addEventListener("click", function(e){
            e.preventDefault();

            const target = document.querySelector(this.getAttribute("href"));

            if(target){
                target.scrollIntoView({
                    behavior:"smooth",
                    block:"start"
                });
            }
        });
    });

    // Button click animation
    const buttons = document.querySelectorAll(".btn");

    buttons.forEach(btn => {
        btn.addEventListener("click", function(){
            this.style.transform = "scale(0.95)";
            setTimeout(() => {
                this.style.transform = "scale(1)";
            },150);
        });
    });

    // Mock exam start
    const startExam = document.getElementById("startExam");

    if(startExam){
        startExam.addEventListener("click", function(){
            window.location.href = "exam.html";
        });
    }

    // Admin Login
    const loginBtn = document.getElementById("adminLogin");

    if(loginBtn){
        loginBtn.addEventListener("click", function(){

            let user = document.getElementById("username").value;
            let pass = document.getElementById("password").value;

            if(user === "admin" && pass === "mei2026"){
                alert("Login Successful");
                window.location.href = "dashboard.html";
            }else{
                alert("Wrong Login Details");
            }

        });
    }

    // Countdown timer for exams
    const timer = document.getElementById("timer");

    if(timer){

        let time = 1800; // 30 minutes

        const countDown = setInterval(() => {

            let minutes = Math.floor(time / 60);
            let seconds = time % 60;

            seconds = seconds < 10 ? "0" + seconds : seconds;

            timer.innerHTML = minutes + ":" + seconds;

            time--;

            if(time < 0){
                clearInterval(countDown);
                alert("Time Up! Exam Submitted.");
            }

        },1000);
    }

});
